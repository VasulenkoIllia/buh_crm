# Copy to `.env` and fill in. Used by docker-compose.yml (prod) and locally.
# Traefik network/entrypoint/certresolver are hardcoded in docker-compose.yml (proxy / websecure / cf).

APP_NAME=buh_crm
APP_DOMAIN=crm.example.com          # the exact domain the app is served on (goes into email links)

PORT=3000
NODE_ENV=production                 # `production` is required for real email + serving the SPA
TZ=Europe/Kyiv
LOG_LEVEL=info

POSTGRES_DB=buh_crm
POSTGRES_USER=buh_crm
POSTGRES_PASSWORD=change-me-strong
# In compose the app gets DATABASE_URL pointing at the `db` service; only needed here for non-compose runs:
DATABASE_URL=postgresql://buh_crm:change-me-strong@db:5432/buh_crm

SESSION_SECRET=change-me-long-random-string   # e.g. `openssl rand -base64 36`

# First admin — created automatically on first boot ONLY while the users table is
# empty (safe to leave set; ignored once any user exists). Password >= 8 chars.
BOOTSTRAP_ADMIN_EMAIL=admin@crm.example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-min-8-chars
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=User

# Email (SMTP). NOTE: STARTTLS (port 587) → SMTP_SECURE=false; implicit TLS (port 465) → SMTP_SECURE=true.
# MAIL_FROM should equal SMTP_USER (most servers only send from the authenticated address).
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=crm@example.com
SMTP_PASS=
MAIL_FROM=crm@example.com
