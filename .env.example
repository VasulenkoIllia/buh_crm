APP_NAME=buh_crm
APP_DOMAIN=crm.example.com

PORT=3000
NODE_ENV=production
TZ=Europe/Kyiv
LOG_LEVEL=info

TRAEFIK_NETWORK=proxy
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS=true
TRAEFIK_CERTRESOLVER=cf

POSTGRES_DB=buh_crm
POSTGRES_USER=buh_crm
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://buh_crm:change-me@localhost:5432/buh_crm

SESSION_SECRET=change-me-long-random-string

# First admin — created automatically on first boot ONLY while the users table is
# empty (safe to leave set; ignored once any user exists). Password >= 8 chars.
BOOTSTRAP_ADMIN_EMAIL=admin@crm.example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-min-8-chars
BOOTSTRAP_ADMIN_FIRST_NAME=Admin
BOOTSTRAP_ADMIN_LAST_NAME=User

# Email (dev = Mailpit; prod = real provider, see docs/integrations.md)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=crm@example.com
